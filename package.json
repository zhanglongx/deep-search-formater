{
  "name": "deep-research-formatter",
  "version": "0.3.2",
  "private": true,
  "description": "An Obsidian plugin that normalizes ChatGPT Deep Research markdown exports.",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "build:cli": "node esbuild.config.mjs cli",
    "dev": "node esbuild.config.mjs",
    "preformat:vault": "npm run build:cli",
    "format:vault": "node dist/cli.js",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "esbuild": "^0.28.0",
    "obsidian": "^1.12.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
